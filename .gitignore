# ── Security & Auth ───────────────────────────────────────────────────────────
# SQLite databases contain sensitive student biometric data (face encodings)
*.db
*.sqlite
*.sqlite3

# Environment / secrets — never commit credentials or keys
.env
.env.*
secrets.py
config.py
*_secret*
*_credentials*

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/
*.whl

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.virtualenv/

# ── ML / Model cache ─────────────────────────────────────────────────────────
# Large pre-trained model files downloaded at runtime
.model_cache/
*.task
*.tflite
*.pt
*.pth
*.onnx
*.h5
*.pb

# DeepFace model cache (stored in home dir but including just in case)
.deepface/

# ── IDE & OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db
.DS_Store
desktop.ini

# ── Logs & temp ───────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.swp

# ── Exports ───────────────────────────────────────────────────────────────────
# CSV exports generated by the admin dashboard
Attendance_Report*.csv
